<?xml version="1.0" encoding="UTF-8"?>
<turtle:Program xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:turtle="http://www.example.org/turtle" xsi:schemaLocation="http://www.example.org/turtle ../../nl.tue.dsldesign.turtle/model/turtle.ecore">
  <statements xsi:type="turtle:Assignment" var="x">
    <expr xsi:type="turtle:RealConst"/>
  </statements>
  <statements xsi:type="turtle:Assignment" var="y">
